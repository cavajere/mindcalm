generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  name                   String
  firstName              String?
  lastName               String?
  phone                  String?
  notes                  String?
  role                   UserRole  @default(STANDARD)
  isActive               Boolean   @default(true)
  licenseExpiresAt       DateTime?
  sessionVersion         Int       @default(0)
  inviteTokenHash        String?
  inviteExpiresAt        DateTime?
  invitedAt              DateTime?
  resetPasswordTokenHash String?
  resetPasswordExpiresAt DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  analyticsEvents        AnalyticsEvent[]
  auditLogs              AuditLog[] @relation("AuditLogActor")
  playbackSessions       PlaybackSession[]
  createdInviteCodes     InviteCode[] @relation("InviteCodeCreator")
  redeemedInviteCodes    InviteCode[] @relation("InviteCodeRedeemer")
  notificationPreference UserNotificationPreference?
  notificationDispatchJobs NotificationDispatchJob[]
  campaigns              Campaign[]
  termsAcceptances       UserTermsAcceptance[]
  eventBookingInvitations EventBookingInvitation[] @relation("EventBookingInvitationUser")

  @@index([role])
  @@map("admin_users")
}

model TermsPolicy {
  id                String               @id @default(uuid())
  status            TermsPolicyStatus    @default(DRAFT)
  currentVersionId  String?              @unique
  currentVersion    TermsPolicyVersion?  @relation("TermsPolicyCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  versions          TermsPolicyVersion[]

  @@map("terms_policies")
}

model TermsPolicyVersion {
  id                  String                          @id @default(uuid())
  termsPolicyId       String
  termsPolicy         TermsPolicy                     @relation(fields: [termsPolicyId], references: [id], onDelete: Cascade)
  currentForPolicy    TermsPolicy?                    @relation("TermsPolicyCurrentVersion")
  versionNumber       Int
  status              TermsPolicyVersionStatus        @default(DRAFT)
  publishedAt         DateTime?
  previousVersionId   String?
  previousVersion     TermsPolicyVersion?             @relation("TermsPolicyVersionPrevious", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions        TermsPolicyVersion[]            @relation("TermsPolicyVersionPrevious")
  translations        TermsPolicyVersionTranslation[]
  pendingRegistrations PendingRegistration[]
  acceptances         UserTermsAcceptance[]
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt

  @@unique([termsPolicyId, versionNumber])
  @@index([termsPolicyId, status])
  @@map("terms_policy_versions")
}

model TermsPolicyVersionTranslation {
  id          String             @id @default(uuid())
  versionId    String
  version      TermsPolicyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  lang         String
  title        String?
  html         String
  buttonLabel  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([versionId, lang])
  @@index([lang])
  @@map("terms_policy_version_translations")
}

model UserTermsAcceptance {
  id                  String             @id @default(uuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  termsPolicyVersionId String
  termsPolicyVersion  TermsPolicyVersion @relation(fields: [termsPolicyVersionId], references: [id], onDelete: Restrict)
  source              String             @default("SELF_SERVICE")
  ipHash              String?
  userAgent           String?
  acceptedAt          DateTime           @default(now())
  createdAt           DateTime           @default(now())

  @@unique([userId, termsPolicyVersionId])
  @@index([userId, acceptedAt])
  @@index([termsPolicyVersionId])
  @@map("user_terms_acceptances")
}

model SubscriptionPolicy {
  id                   String                      @id @default(uuid())
  status               SubscriptionPolicyStatus    @default(DRAFT)
  currentVersionId     String?                     @unique
  currentVersion       SubscriptionPolicyVersion?  @relation("SubscriptionPolicyCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  subscribeEnabled     Boolean                     @default(true)
  subscribeConfirmEmail Boolean                    @default(false)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  versions             SubscriptionPolicyVersion[]
  consentFormulas      ConsentFormula[]

  @@map("subscription_policies")
}

model SubscriptionPolicyVersion {
  id                   String                                @id @default(uuid())
  subscriptionPolicyId String
  subscriptionPolicy   SubscriptionPolicy                    @relation(fields: [subscriptionPolicyId], references: [id], onDelete: Cascade)
  currentForPolicy     SubscriptionPolicy?                   @relation("SubscriptionPolicyCurrentVersion")
  versionNumber        Int
  status               SubscriptionPolicyVersionStatus       @default(DRAFT)
  publishedAt          DateTime?
  previousVersionId    String?
  previousVersion      SubscriptionPolicyVersion?            @relation("SubscriptionPolicyVersionPrevious", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions         SubscriptionPolicyVersion[]           @relation("SubscriptionPolicyVersionPrevious")
  translations         SubscriptionPolicyVersionTranslation[]
  consentFormulaVersions ConsentFormulaVersion[]
  consents             Consent[]
  createdAt            DateTime                              @default(now())
  updatedAt            DateTime                              @updatedAt

  @@unique([subscriptionPolicyId, versionNumber])
  @@index([subscriptionPolicyId, status])
  @@map("subscription_policy_versions")
}

model SubscriptionPolicyVersionTranslation {
  id          String                    @id @default(uuid())
  versionId   String
  version     SubscriptionPolicyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  lang        String
  title       String?
  html        String
  buttonLabel String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([versionId, lang])
  @@index([lang])
  @@map("subscription_policy_version_translations")
}

model ConsentFormula {
  id                   String                     @id @default(uuid())
  subscriptionPolicyId String
  subscriptionPolicy   SubscriptionPolicy         @relation(fields: [subscriptionPolicyId], references: [id], onDelete: Cascade)
  code                 String
  required             Boolean                    @default(false)
  status               ConsentFormulaStatus       @default(ACTIVE)
  currentVersionId     String?                    @unique
  currentVersion       ConsentFormulaVersion?     @relation("ConsentFormulaCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions             ConsentFormulaVersion[]
  consents             Consent[]
  audienceFilters      CampaignAudienceFilter[]
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt

  @@unique([subscriptionPolicyId, code])
  @@index([subscriptionPolicyId, status])
  @@map("consent_formulas")
}

model ConsentFormulaVersion {
  id                          String                          @id @default(uuid())
  consentFormulaId            String
  consentFormula              ConsentFormula                  @relation(fields: [consentFormulaId], references: [id], onDelete: Cascade)
  currentForFormula           ConsentFormula?                 @relation("ConsentFormulaCurrentVersion")
  subscriptionPolicyVersionId String
  subscriptionPolicyVersion   SubscriptionPolicyVersion       @relation(fields: [subscriptionPolicyVersionId], references: [id], onDelete: Cascade)
  versionNumber               Int
  status                      ConsentFormulaVersionStatus     @default(DRAFT)
  publishedAt                 DateTime?
  previousVersionId           String?
  previousVersion             ConsentFormulaVersion?          @relation("ConsentFormulaVersionPrevious", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions                ConsentFormulaVersion[]         @relation("ConsentFormulaVersionPrevious")
  translations                ConsentFormulaVersionTranslation[]
  consents                    Consent[]
  createdAt                   DateTime                        @default(now())
  updatedAt                   DateTime                        @updatedAt

  @@unique([consentFormulaId, versionNumber])
  @@index([subscriptionPolicyVersionId])
  @@index([consentFormulaId, status])
  @@map("consent_formula_versions")
}

model ConsentFormulaVersionTranslation {
  id               String                @id @default(uuid())
  consentVersionId String
  consentVersion   ConsentFormulaVersion @relation(fields: [consentVersionId], references: [id], onDelete: Cascade)
  lang             String
  title            String
  text             String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([consentVersionId, lang])
  @@index([lang])
  @@map("consent_formula_version_translations")
}

model Contact {
  id               String         @id @default(uuid())
  email            String         @unique
  firstName        String?
  lastName         String?
  status           ContactStatus  @default(ACTIVE)
  suppressedAt     DateTime?
  suppressionReason String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  consents         Consent[]
  confirmationTokens SubscriptionConfirmationToken[]
  unsubscribeTokens UnsubscribeToken[]
  campaignRecipients CampaignRecipient[]

  @@index([status, createdAt])
  @@map("contacts")
}

model Consent {
  id                     String                @id @default(uuid())
  contactId              String
  contact                Contact               @relation(fields: [contactId], references: [id], onDelete: Cascade)
  consentFormulaId       String
  consentFormula         ConsentFormula        @relation(fields: [consentFormulaId], references: [id], onDelete: Restrict)
  consentFormulaVersionId String
  consentFormulaVersion  ConsentFormulaVersion @relation(fields: [consentFormulaVersionId], references: [id], onDelete: Restrict)
  policyVersionId        String
  policyVersion          SubscriptionPolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Restrict)
  value                  ConsentValue
  status                 ConsentRecordStatus   @default(CONFIRMED)
  invalidatedAt          DateTime?
  invalidationReason     String?
  ipHash                 String?
  userAgent              String?
  source                 ConsentSource         @default(SUBSCRIBE)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  @@index([contactId, consentFormulaId, invalidatedAt])
  @@index([consentFormulaVersionId, value, status, invalidatedAt])
  @@index([policyVersionId])
  @@map("consents")
}

model SubscriptionConfirmationToken {
  id          String   @id @default(uuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([contactId, expiresAt])
  @@map("subscription_confirmation_tokens")
}

model UnsubscribeToken {
  id          String   @id @default(uuid())
  contactId   String
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tokenHash   String   @unique
  expiresAt   DateTime
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([contactId, expiresAt])
  @@map("unsubscribe_tokens")
}

model Campaign {
  id            String            @id @default(uuid())
  name          String
  subject       String
  htmlBody      String
  matchMode     CampaignMatchMode @default(ALL)
  status        CampaignStatus    @default(DRAFT)
  sentAt        DateTime?
  createdByUserId String?
  createdByUser User?             @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  filters       CampaignAudienceFilter[]
  recipients    CampaignRecipient[]

  @@index([status, createdAt])
  @@map("campaigns")
}

model CampaignAudienceFilter {
  id            String   @id @default(uuid())
  campaignId    String
  campaign      Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  consentFormulaId String
  consentFormula ConsentFormula @relation(fields: [consentFormulaId], references: [id], onDelete: Restrict)
  formulaVersionIds String[]
  createdAt     DateTime @default(now())

  @@index([campaignId])
  @@index([consentFormulaId])
  @@map("campaign_audience_filters")
}

model CampaignRecipient {
  id          String                  @id @default(uuid())
  campaignId  String
  campaign    Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId   String
  contact     Contact                 @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status      CampaignRecipientStatus @default(PENDING)
  sentAt      DateTime?
  error       String?
  createdAt   DateTime                @default(now())

  @@unique([campaignId, contactId])
  @@index([status, createdAt])
  @@map("campaign_recipients")
}

model UserNotificationPreference {
  userId                     String                @id
  user                       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifyOnAudio              Boolean               @default(true)
  notifyOnPosts              Boolean               @default(true)
  notifyOnEvents             Boolean               @default(true)
  frequency                  NotificationFrequency @default(NONE)
  lastImmediateContentAt     DateTime?
  lastWeeklyDigestSentAt     DateTime?
  lastMonthlyDigestSentAt    DateTime?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt

  @@map("user_notification_preferences")
}

model NotificationScheduleSettings {
  id               Int      @id
  immediateHourUtc Int      @default(9)
  weeklyHourUtc    Int      @default(9)
  weeklyDayOfWeek  Int      @default(1)
  monthlyHourUtc   Int      @default(9)
  monthlyDayOfMonth Int     @default(1)
  batchSize        Int      @default(20)
  maxAttempts      Int      @default(5)
  retryBaseDelayMinutes Int @default(5)
  lockTimeoutMinutes Int    @default(15)
  retentionDays    Int      @default(30)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("notification_schedule_settings")
}

model NotificationDispatchJob {
  id            String                     @id @default(uuid())
  userId        String
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  dedupeKey     String                     @unique
  frequency     NotificationFrequency
  status        NotificationDispatchStatus @default(PENDING)
  recipientEmail String
  recipientName String
  subject       String
  title         String
  intro         String
  items         Json
  itemCount     Int                        @default(0)
  windowStartedAt DateTime
  windowEndedAt DateTime
  scheduledFor  DateTime
  availableAt   DateTime                   @default(now())
  lockedAt      DateTime?
  startedAt     DateTime?
  sentAt        DateTime?
  failedAt      DateTime?
  lastError     String?
  attemptCount  Int                        @default(0)
  maxAttempts   Int                        @default(5)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  @@index([status, availableAt])
  @@index([userId, frequency, createdAt])
  @@index([scheduledFor])
  @@index([sentAt])
  @@index([failedAt])
  @@map("notification_dispatch_jobs")
}

model ContentPublicationOutbox {
  id           String                 @id @default(uuid())
  dedupeKey    String                 @unique
  contentType  ContentPublicationType
  contentId    String
  title        String
  contentUrl   String?
  publishedAt  DateTime
  status       PublicationOutboxStatus @default(PENDING)
  availableAt  DateTime               @default(now())
  lockedAt     DateTime?
  processedAt  DateTime?
  lastError    String?
  attemptCount Int                    @default(0)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([status, availableAt])
  @@index([contentType, contentId])
  @@index([publishedAt])
  @@map("content_publication_outbox")
}

model Event {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  body        String
  bodyText    String    @default("")
  excerpt     String?
  organizer   String
  city        String
  venue       String?
  startsAt    DateTime
  endsAt      DateTime?
  bookingEnabled Boolean @default(false)
  bookingCapacity Int?
  bookingReservedSeats Int @default(0)
  bookingOpensAt DateTime?
  bookingClosesAt DateTime?
  participationMode EventParticipationMode @default(FREE)
  participationPriceCents Int?
  visibility  ContentVisibility @default(REGISTERED)
  coverImage  String?
  coverImageOriginalName String?
  coverImageDisplayName  String?
  coverAlbumImageId String?
  coverAlbumImage AlbumImage? @relation("EventCoverAlbumImage", fields: [coverAlbumImageId], references: [id], onDelete: SetNull)
  cancelledAt DateTime?
  cancellationMessage String?
  status      Status    @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bookingInvitations EventBookingInvitation[]
  bookings    EventBooking[]

  @@index([coverAlbumImageId])
  @@index([bookingEnabled])
  @@index([status, visibility])
  @@index([slug])
  @@index([startsAt])
  @@map("events")
}

model EventBookingInvitation {
  id            String   @id @default(uuid())
  eventId        String
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?    @relation("EventBookingInvitationUser", fields: [userId], references: [id], onDelete: SetNull)
  recipientEmail String
  recipientName  String?
  recipientFirstName String?
  recipientLastName  String?
  recipientPhone     String?
  note               String?
  tokenHash      String   @unique
  expiresAt      DateTime
  lastSentAt     DateTime?
  usedAt         DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  booking        EventBooking?

  @@unique([eventId, recipientEmail])
  @@index([eventId, recipientEmail])
  @@index([eventId, expiresAt])
  @@index([userId])
  @@index([revokedAt, expiresAt])
  @@map("event_booking_invitations")
}

model EventBooking {
  id              String             @id @default(uuid())
  eventId          String
  event            Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitationId     String             @unique
  invitation       EventBookingInvitation @relation(fields: [invitationId], references: [id], onDelete: Restrict)
  status           EventBookingStatus @default(CONFIRMED)
  bookerFirstName  String
  bookerLastName   String
  bookerPhone      String
  seatsReserved    Int
  cancelledAt      DateTime?
  cancelReason     String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  participants     EventBookingParticipant[]

  @@index([eventId, status, createdAt])
  @@map("event_bookings")
}

model EventBookingParticipant {
  id         String   @id @default(uuid())
  bookingId   String
  booking     EventBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  phone       String?
  isBooker    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([bookingId, isBooker])
  @@map("event_booking_participants")
}

model InviteCode {
  id                   String                  @id @default(uuid())
  code                 String                  @unique
  licenseDurationDays  Int
  maxRedemptions       Int                     @default(1)
  redemptionsCount     Int                     @default(0)
  status               InviteCodeStatus        @default(ACTIVE)
  expiresAt            DateTime?
  redeemedAt           DateTime?
  redeemedByUserId     String?
  redeemedByUser       User?                   @relation("InviteCodeRedeemer", fields: [redeemedByUserId], references: [id], onDelete: SetNull)
  createdByUserId      String?
  createdByUser        User?                   @relation("InviteCodeCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  notes                String?
  pendingRegistrations PendingRegistration[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@index([status, createdAt])
  @@index([expiresAt])
  @@map("invite_codes")
}

model PendingRegistration {
  id                    String                    @id @default(uuid())
  inviteCodeId          String
  inviteCode            InviteCode                @relation(fields: [inviteCodeId], references: [id], onDelete: Restrict)
  termsPolicyVersionId  String?
  termsPolicyVersion    TermsPolicyVersion?       @relation(fields: [termsPolicyVersionId], references: [id], onDelete: SetNull)
  termsAcceptedAt       DateTime?
  email                 String
  passwordHash          String
  firstName             String
  lastName              String
  phone                 String
  verificationTokenHash String                    @unique
  verificationExpiresAt DateTime
  verifiedAt            DateTime?
  status                PendingRegistrationStatus @default(PENDING)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([email, status])
  @@index([verificationExpiresAt])
  @@map("pending_registrations")
}

model SmtpSettings {
  id                Int      @id
  host              String
  port              Int
  secure            Boolean  @default(false)
  username          String?
  passwordEncrypted String?
  fromEmail         String
  fromName          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("smtp_settings")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  color       String?
  icon        String?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  audios      Audio[]

  @@map("categories")
}

model Audio {
  id          String    @id @default(uuid())
  title       String
  description String
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id])
  level       Level     @default(BEGINNER)
  durationSec Int
  audioFile   String
  audioOriginalName String
  audioDisplayName  String
  audioFormat String
  audioSize   Int
  streamingFormat StreamingFormat @default(DIRECT)
  processingStatus AudioProcessingStatus @default(READY)
  hlsManifestPath String?
  processingError String?
  coverImage  String?
  coverImageOriginalName String?
  coverImageDisplayName  String?
  coverAlbumImageId String?
  coverAlbumImage AlbumImage? @relation("AudioCoverAlbumImage", fields: [coverAlbumImageId], references: [id], onDelete: SetNull)
  status      Status    @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  analyticsEvents AnalyticsEvent[]
  audioTags   AudioTag[]
  playbackSessions PlaybackSession[]

  @@index([categoryId])
  @@index([coverAlbumImageId])
  @@index([status])
  @@index([level])
  @@map("audio")
}

model Post {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  body        String
  bodyText    String    @default("")
  excerpt     String?
  author      String
  visibility  ContentVisibility @default(REGISTERED)
  coverImage  String?
  coverImageOriginalName String?
  coverImageDisplayName  String?
  coverAlbumImageId String?
  coverAlbumImage AlbumImage? @relation("PostCoverAlbumImage", fields: [coverAlbumImageId], references: [id], onDelete: SetNull)
  status      Status    @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  analyticsEvents AnalyticsEvent[]
  postTags PostTag[]

  @@index([coverAlbumImageId])
  @@index([status, visibility])
  @@index([slug])
  @@map("posts")
}

model AlbumImage {
  id          String    @id @default(uuid())
  filePath    String    @unique
  originalName String
  displayName String
  title       String?
  description String?
  mimeType    String
  size        Int
  fileHash    String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  audioCoverFor Audio[] @relation("AudioCoverAlbumImage")
  postCoverFor Post[] @relation("PostCoverAlbumImage")
  eventCoverFor Event[] @relation("EventCoverAlbumImage")

  @@index([createdAt])
  @@map("album_images")
}

model Tag {
  id          String       @id @default(uuid())
  label       String
  slug        String       @unique
  description String?
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  aliases     TagAlias[]
  audioTags   AudioTag[]
  postTags PostTag[]

  @@index([isActive, sortOrder])
  @@index([label])
  @@map("tags")
}

model TagAlias {
  id        String   @id @default(uuid())
  tagId     String
  alias     String
  createdAt DateTime @default(now())
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, alias])
  @@index([alias])
  @@index([tagId])
  @@map("tag_aliases")
}

model AudioTag {
  audioId String
  tagId   String
  audio   Audio @relation(fields: [audioId], references: [id], onDelete: Cascade)
  tag     Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([audioId, tagId])
  @@index([tagId, audioId])
  @@map("audio_tags")
}

model PostTag {
  postId String
  tagId     String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId, postId])
  @@map("post_tags")
}

model AnalyticsEvent {
  id          String               @id @default(uuid())
  userId      String?
  user        User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  contentType AnalyticsContentType
  eventType   AnalyticsEventType
  audioId     String?
  audio       Audio?               @relation(fields: [audioId], references: [id])
  postId   String?
  post     Post?             @relation(fields: [postId], references: [id])
  metadata    Json?
  occurredAt  DateTime             @default(now())

  @@index([occurredAt])
  @@index([eventType, occurredAt])
  @@index([audioId, occurredAt])
  @@index([postId, occurredAt])
  @@index([userId, occurredAt])
  @@map("analytics_events")
}

model AuditLog {
  id          String          @id @default(uuid())
  actorUserId String?
  actorUser   User?           @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorEmail  String?
  actorName   String?
  actorRole   UserRole?
  action      AuditAction
  entityType  AuditEntityType
  entityId    String?
  entityLabel String?
  outcome     AuditOutcome    @default(SUCCESS)
  ipAddress   String?
  userAgent   String?
  requestPath String?
  requestMethod String?
  requestId   String?
  metadata    Json?
  occurredAt  DateTime        @default(now())

  @@index([occurredAt])
  @@index([action, occurredAt])
  @@index([entityType, occurredAt])
  @@index([actorUserId, occurredAt])
  @@index([outcome, occurredAt])
  @@map("audit_logs")
}

model PlaybackSession {
  id         String   @id @default(uuid())
  userId     String
  audioId    String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  startedAt  DateTime?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audio      Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([audioId, expiresAt])
  @@index([userId, revokedAt, expiresAt])
  @@map("playback_sessions")
}

