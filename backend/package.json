{
  "name": "mindcalm-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "audio:backfill-hls": "tsx src/scripts/backfillAudioToHls.ts",
    "storage:cleanup": "tsx src/scripts/reconcileStorage.ts"
  },
  "dependencies": {
    "@mindcalm/design-tokens": "file:../packages/design-tokens",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.0",
    "ffmpeg-static": "^5.3.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "music-metadata": "^10.6.0",
    "nodemailer": "^6.10.1",
    "sanitize-html": "^2.14.0",
    "slugify": "^1.6.6",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/sanitize-html": "^2.13.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
