# Database
DATABASE_URL=postgresql://mindcalm:mindcalm@localhost:5435/mindcalm

# Server
PORT=3300
NODE_ENV=development

# Auth
JWT_SECRET=cambia-con-stringa-casuale-di-almeno-32-caratteri
JWT_EXPIRES_IN=1h

# Storage
AUDIO_STORAGE_PATH=./storage/audio
HLS_STORAGE_PATH=./storage/hls
IMAGES_STORAGE_PATH=./storage/images
MAX_AUDIO_SIZE_MB=100
MAX_IMAGE_SIZE_MB=5
FFMPEG_PATH=

# CORS
CORS_ORIGIN=http://localhost:5473,http://localhost:5474

# Rate limiting
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_LOGIN=30

# Bootstrap admin
# Valido solo finché non esiste almeno un admin attivo nel DB.
ADMIN_NAME=MindCalm Bootstrap
ADMIN_EMAIL=bootstrap-admin@example.invalid
ADMIN_PASSWORD=Sostituisci-con-una-password-bootstrap-forte
