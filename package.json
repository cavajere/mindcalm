{
  "name": "mindcalm",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "frontend",
    "admin"
  ],
  "scripts": {
    "dev:start": "node scripts/dev/start.js",
    "dev:stop": "node scripts/dev/stop.js",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:admin": "npm run dev --workspace=admin",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\"",
    "build:frontend": "npm run build --workspace=frontend",
    "build:admin": "npm run build --workspace=admin",
    "build": "npm run build:frontend && npm run build:admin",
    "test:backend": "npm run test --workspace=backend",
    "db:migrate": "npm run db:migrate --workspace=backend",
    "db:seed": "npm run db:seed --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
