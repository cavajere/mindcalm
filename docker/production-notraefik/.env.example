# =============================================================================
# MindCalm - Configurazione Produzione (VM Proxmox / Ubuntu Server)
# =============================================================================
#
# Stack MindCalm senza Traefik integrato.
# Il reverse proxy e i certificati SSL sono gestiti dal Traefik Gateway sul NAS.
#
# ISTRUZIONI:
#   1. Copia questo file: cp .env.example .env
#   2. Modifica TUTTI i valori contrassegnati con <cambia>
#   3. Esegui: docker compose up -d
#
# =============================================================================

# =============================================================================
# PORTA
# =============================================================================

# Porta esposta sul NAS (Traefik Gateway -> 192.168.0.123:3003)
API_PORT=3003

# =============================================================================
# DATABASE POSTGRESQL
# =============================================================================

POSTGRES_USER=mindcalm
POSTGRES_PASSWORD=<cambia>
POSTGRES_DB=mindcalm
POSTGRES_DATA_PATH=./data/postgres

# =============================================================================
# JWT SECRET
# =============================================================================

JWT_SECRET=<cambia-stringa-casuale-di-almeno-32-caratteri>
JWT_EXPIRES_IN=1h

# =============================================================================
# ADMIN (prima installazione — eseguire seed manualmente o via entrypoint)
# =============================================================================

ADMIN_EMAIL=admin@mindcalm.com
ADMIN_PASSWORD=<cambia>

# =============================================================================
# STORAGE LIMITS
# =============================================================================

MAX_AUDIO_SIZE_MB=100
MAX_IMAGE_SIZE_MB=5

# =============================================================================
# SECURITY
# =============================================================================

CORS_ORIGIN=https://mindcalm.datagestio.com
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_LOGIN=30
