# =============================================================================
# MindCalm - Configurazione App (senza Traefik)
# =============================================================================
#
# File esempio per produzione/self-hosting.
# Contiene placeholder pseudoreali e deve essere personalizzato prima del deploy.
#
# Da sostituire sempre:
#   - POSTGRES_PASSWORD
#   - JWT_SECRET
#   - ADMIN_EMAIL / ADMIN_PASSWORD
#   - CORS_ORIGIN
#
# Il bootstrap admin da ENV è temporaneo:
#   - funziona solo finché non esiste almeno un admin attivo nel database
#   - dopo la creazione del primo admin reale, queste credenziali smettono di valere
#
# =============================================================================

# =============================================================================
# GENERALE
# =============================================================================

# Versione immagine Docker
VERSION=latest

# Branch git da deployare con deploy.sh
DEPLOY_BRANCH=main

# Porta API esposta sulla LAN (raggiungibile dal Traefik Gateway sul NAS)
API_PORT=3003

# =============================================================================
# DATABASE POSTGRESQL
# =============================================================================

# Personalizza per la tua installazione
POSTGRES_USER=mindcalm_prod
POSTGRES_PASSWORD=CHANGE-ME-postgres-password
POSTGRES_DB=mindcalm_prod
POSTGRES_DATA_PATH=./data/postgres

# =============================================================================
# JWT SECRET
# =============================================================================
#
# IMPORTANTE: Genera un valore unico per ogni installazione!
# Comando: openssl rand -base64 32
#

# Genera con: openssl rand -base64 32
JWT_SECRET=CHANGE-ME-jwt-secret-generated-with-openssl-rand-base64-32
JWT_EXPIRES_IN=1h

# =============================================================================
# BOOTSTRAP ADMIN (prima installazione / recovery controllata)
# =============================================================================
#
# Credenziali temporanee per il bootstrap admin.
# Sono valide solo se non esiste ancora almeno un admin attivo nel DB.
#

ADMIN_NAME=MindCalm Bootstrap
ADMIN_EMAIL=bootstrap-admin@example.invalid
ADMIN_PASSWORD=CHANGE-ME-bootstrap-admin-password

# =============================================================================
# STORAGE LIMITS
# =============================================================================

MAX_AUDIO_SIZE_MB=100
MAX_IMAGE_SIZE_MB=5

# =============================================================================
# SECURITY
# =============================================================================

# Dominio pubblico dell'app (deve corrispondere al dominio servito dal reverse proxy)
CORS_ORIGIN=https://mindcalm.example.com
TRUST_PROXY=1

# Rate limiting (richieste per finestra temporale)
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_LOGIN=30
RATE_LIMIT_INVITE_CODE_VALIDATION=20
RATE_LIMIT_REGISTRATION=10
RATE_LIMIT_REGISTRATION_VERIFICATION=20

# Registrazione utenti self-service
REGISTRATION_VERIFICATION_EXPIRES_IN_HOURS=24
