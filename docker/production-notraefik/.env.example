# =============================================================================
# MindCalm - Configurazione App (senza Traefik)
# =============================================================================
#
# !!  ATTENZIONE: VALORI DEMO PRE-CONFIGURATI !!
#
# Questo file contiene valori DEMO funzionanti per testare rapidamente il deploy.
#
# IN PRODUZIONE REALE DEVI CAMBIARE:
#   - Tutte le password (POSTGRES_PASSWORD, ADMIN_PASSWORD)
#   - Il secret JWT (genera nuovo valore!)
#
# Questo file configura lo stack applicativo (VM Proxmox o altra macchina sulla LAN).
# Il reverse proxy e SSL sono gestiti dal Traefik Gateway sul NAS Synology.
#
# ISTRUZIONI:
#   1. Copia: cp .env.example .env
#   2. Per DEMO: puoi usare cosi' com'e'
#   3. Per PRODUZIONE: modifica TUTTI i valori sensibili!
#   4. Esegui: docker compose up -d
#
# =============================================================================

# =============================================================================
# GENERALE
# =============================================================================

# Versione immagine Docker
VERSION=latest

# Porta API esposta sulla LAN (raggiungibile dal Traefik Gateway sul NAS)
API_PORT=3003

# =============================================================================
# DATABASE POSTGRESQL
# =============================================================================

# !! CAMBIA IN PRODUZIONE
POSTGRES_USER=mindcalm_demo
POSTGRES_PASSWORD=DemoPassword2024SecureDB!
POSTGRES_DB=mindcalm_demo
POSTGRES_DATA_PATH=./data/postgres

# =============================================================================
# JWT SECRET
# =============================================================================
#
# IMPORTANTE: Genera un valore unico per ogni installazione!
# Comando: openssl rand -base64 32
#

# !! CAMBIA IN PRODUZIONE - genera con: openssl rand -base64 32
JWT_SECRET=mC4lm9xK2wR7tY5uI8oP3aS6dF1gH0jK4lZ7xCvBnMq=
JWT_EXPIRES_IN=1h

# =============================================================================
# ADMIN (prima installazione)
# =============================================================================
#
# Credenziali per l'admin (seed al primo avvio)
#

# !! CAMBIA IN PRODUZIONE
ADMIN_EMAIL=admin@mindcalm.com
ADMIN_PASSWORD=DemoAdmin2024Secure!

# =============================================================================
# STORAGE LIMITS
# =============================================================================

MAX_AUDIO_SIZE_MB=100
MAX_IMAGE_SIZE_MB=5

# =============================================================================
# SECURITY
# =============================================================================

# Dominio per CORS (deve corrispondere al dominio configurato su Traefik)
CORS_ORIGIN=https://mindcalm.datagestio.com

# Rate limiting (richieste per finestra temporale)
RATE_LIMIT_PUBLIC=100
RATE_LIMIT_LOGIN=30
RATE_LIMIT_INVITE_CODE_VALIDATION=20
RATE_LIMIT_REGISTRATION=10
RATE_LIMIT_REGISTRATION_VERIFICATION=20

# Registrazione utenti self-service
REGISTRATION_VERIFICATION_EXPIRES_IN_HOURS=24
